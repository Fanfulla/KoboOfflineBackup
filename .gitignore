.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
*.zip

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Testing
coverage/
.nyc_output/
*.lcov
.coverage
htmlcov/
test-results/
playwright-report/

# Temporary files
tmp/
temp/
*.tmp
*.temp
.cache/

# Package manager files
package-lock.json.backup
yarn.lock.backup
.pnpm-store/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

