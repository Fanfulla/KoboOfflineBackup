# .gitignore for Kobo Backup Manager
# React + Vite + JavaScript project

# Dependencies
node_modules/
/.pnp
.pnp.js

# Build outputs
dist/
dist-ssr/
build/
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# IDE - VSCode
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# IDE - IntelliJ / WebStorm
.idea/
*.iml
*.iws
out/

