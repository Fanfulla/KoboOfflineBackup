*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
env/
.venv

# Certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx

# Local development
.local/
local/
scratch/

# Ignore nul file (appears to be an error file)
nul

# Keep .claude directory (GSD workflow files)
!.claude/

# Keep public directory for static assets
!public/

# Keep important documentation
!README.md
!LICENSE
!CONTRIBUTING.md
!CODE_OF_CONDUCT.md
